# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# --- NVIDIA NIM (default LLM provider, OpenAI-compatible API) ---
NVIDIA_API_KEY=

# --- Reddit provider (optional; enable in config/default.yaml) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- YouTube Data API provider (optional; enable in config/default.yaml) ---
YOUTUBE_API_KEY=

# ===== Stage 2 (Shorts generation) — all optional; config/shorts.yaml =====
# Script generation (Gemini Flash primary; Groq / OpenRouter fallbacks):
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Stock footage (optional; pollinations image gen needs no key):
PEXELS_API_KEY=
PIXABAY_API_KEY=
# YouTube upload (optional; OAuth client secrets JSON path):
YOUTUBE_CLIENT_SECRETS=
